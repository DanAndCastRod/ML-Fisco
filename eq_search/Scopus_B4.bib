@ARTICLE{Behrends20222,
	author = {Behrends, Matheus Peixoto},
	title = {Under Which Conditions Would the ATAD’s GAAR Benefit from Automatic Decision-Making in Terms of Legal Certainty and Efficiency?},
	year = {2022},
	journal = {International Tax Studies},
	volume = {2022},
	number = {7},
	pages = {2 - 19},
	doi = {10.59403/2gyn7pt},
	url = {https://www.scopus.com/pages/publications/85148585942?origin=resultslist},
	affiliations = {International Tax Law, the University of Amsterdam and IBFD, Netherlands},
	abstract = {In this article, the author scrutinized the limitations on tax administrations when it comes to enhancing legal certainty and efficiency via automatica decision-making (ADM) models until the Anti-Tax Avoidance Directive and general anti-avoidance rules. A lack of clarity and certainty is identified under the Anti-Tax Avoidance Directive's general anti-avoidance rule framework. To curb this issue, the Court of Justice of the European Union's case lae is a vital source for enhancing integrability with any ADM model. Taxpayers' rights are found to be limited by transparency breaches and data misuse under ADM, mainly in respect of black-box models. An ideal hybrid approach is identified for artificial intelligence, via machine learning and traditional computer mechanisms, since it uses sufficiently less data and requires only a good model understanding. Based on a practical simulation approach, facts and patterns are extracted from case law. If certain conditions are met, findings show that, departing from the Anti-Tax Avoidance Directive's general anti-abuse rule tests, the motive and artificiality test are more prone to automatization than the defeat-of-object-of-purpose test. All of them benefit from the case law of the Court of Justice of the European Union on automated scenarios. Thus, the application of enhanced ADM model issues may be addressed by including human beings in the loop. © 2022, International Bureau of Fiscal Documentation (IBFD). All rights reserved.},
	correspondence_address = {M.P. Behrends; International Tax Law, the University of Amsterdam and IBFD, Netherlands; email: matheus.behrends@alumni.usp.br},
	publisher = {International Bureau of Fiscal Documentation (IBFD)},
	issn = {25901117},
	language = {English},
	abbrev_source_title = {Int. Tax. Stud.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@BOOK{Koukoulioti2025411,
	author = {Koukoulioti, Vasiliki and Lindsay, Ira K.},
	title = {Tax administration},
	year = {2025},
	journal = {Elgar Concise Encyclopedia of Artificial Intelligence and the Law},
	pages = {411 - 414},
	doi = {10.4337/9781035336906.00107},
	url = {https://www.scopus.com/pages/publications/105032148907?origin=resultslist},
	affiliations = {Queen Mary University of London, United Kingdom; Head of Surrey Law School, United Kingdom},
	abstract = {The past several years have seen widespread adoption of artificial intelligence (AI) by tax administrations, bringing with it both potential benefits and risks. If employed effectively, AI could improve the efficiency of fraud detection and tax audits, provide better advice for taxpayers and strengthen tax authorities’ compliance with the law. However, these same developments raise concerns regarding privacy violations, lack of transparency, and potential discrimination. Adoption of AI risks undermining accountability and transparency in tax administration, facilitating invasive surveillance of taxpayers, and subjecting taxpayers to decisions that cannot be explained or evaluated in terms of procedural fairness. As AI tools become widespread, this will require rethinking of taxpayer’s rights and tax authorities’ legal obligations. © The Editors and Contributors Severally 2025. All rights reserved.},
	author_keywords = {AI; Privacy; Tax; Tax administration; Taxation; Transparency},
	keywords = {Artificial intelligence; Data privacy; Taxation; Artificial intelligence tools; Fraud detection; Legal obligations; Potential benefits; Potential risks; Privacy; Privacy violation; Procedural fairness; Tax administration; Tax authorities; Transparency},
