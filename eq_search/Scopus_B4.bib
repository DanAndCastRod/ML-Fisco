	year = {2025},
	journal = {Proceedings - International Conference on Advanced Computer Information Technologies, ACIT},
	pages = {420 - 424},
	doi = {10.1109/ACIT65614.2025.11185459},
	url = {https://www.scopus.com/pages/publications/105019950265?origin=resultslist},
	affiliations = {Ternopil I. Puluj National Technical University, Department of Accounting and Audit, Ternopil, Ukraine; West Ukrainian National University, S. I. Yuriy Department of Finance, Ternopil, Ukraine; West Ukrainian National University, S. Yuriy Department of Finance, Ternopil, Ukraine},
	abstract = {Digitalization is transforming tax systems by automating routine operations, enhancing data accuracy, and reducing administrative costs, exemplified by e-reporting systems like SAF-T and Ukraine's e-Taxpayer Cabinet, which boost transparency and convenience. AI and big data analytics improve compliance by detecting anomalies and predicting revenue, while blockchain and smart contracts enhance security and transparency, minimizing fraud. New approaches include digital service taxes, biometric identification, AI-driven risk control, mobile apps, and gamification to encourage compliance. The proposed conceptual model addresses technological, legal, security, organizational, and social barriers through automated platforms, unified digital ecosystems, blockchain, adaptive electronic taxation, and smart contracts aimed at efficiency and transparency. However, challenges such as high implementation costs, cybersecurity risks, and infrastructure gaps remain, requiring solutions like secure data protection and standardized frameworks. Overcoming these obstacles is essential for creating a modern, efficient, and trusted tax system that meets the needs of the digital economy, reduces the shadow economy, and fosters equitable conditions for all taxpayers. Expected outcomes include enhanced transparency, reduced administrative burdens, and strengthened trust in tax authorities, leading to a tax system that is both effective and accessible for citizens and businesses. © 2025 IEEE.},
	author_keywords = {artificial intelligence; automation; blockchain; digitalization; e-reporting; taxation; transparency},
	keywords = {Advanced Analytics; Big data; Biometrics; Data privacy; Economics; Information systems; Network security; Smart contract; Taxation; Administrative cost; Block-chain; Data accuracy; Data analytics; Digitalization; E-reporting; New approaches; Reporting systems; Tax systems; Ukraine; Artificial intelligence; Automation; Transparency},
