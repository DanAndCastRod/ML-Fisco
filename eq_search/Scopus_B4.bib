@ARTICLE{Errichetti2018107,
	author = {Errichetti, Jacob and Roohani, Saeed J.},
	title = {The merit of the DATA act to enhance the governmental reporting process: A corporate governance perspective},
	year = {2018},
	journal = {Journal of Emerging Technologies in Accounting},
	volume = {15},
	number = {1},
	pages = {107 - 120},
	doi = {10.2308/jeta-52092},
	url = {https://www.scopus.com/pages/publications/85051379081?origin=resultslist},
	affiliations = {Certified Public Accountant; Bryant University, United States},
	abstract = {This paper utilizes corporate governance concepts to assess the merit of the Digital Accountability and Transparency Act of 2014 (DATA Act). The paper first compares the information flows seen in a corporate context to those seen in a governmental reporting context. The paper then utilizes agency theory to establish a conceptual link between the two reporting processes. This conceptual link is used to identify common goals between the participants in the information flows. Following this, a corporate governance model is used to outline factors that contribute to effective corporate governance. This governance model is then used as a basis for assessing the merit of the DATA Act. After this, differences between the participants in the information flows are discussed and limitations of the paper are acknowledged. The paper suggests that the DATA Act has merit due to its potential to improve transparency and monitoring in the governmental reporting process. Increased data timeliness and usability will enhance transparency, while improvements in automation, data transfer, and data analytics will improve monitoring. The conclusions of this paper have implications for the participants in the governmental reporting process including government agencies, legislators, regulatory bodies, contractors, nonvoting taxpayers, and members of the voting public. © 2018, American Accounting Association. All rights reserved.},
	author_keywords = {Agency theory; Corporate governance; DATA Act; Governmental reporting; XBRL},
	publisher = {American Accounting Association},
	issn = {15541908},
	language = {English},
	abbrev_source_title = {J. Emerg. Technol. Account.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 4}
}

