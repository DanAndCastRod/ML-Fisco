@ARTICLE{Laverde202540,
	author = {Laverde, Sandra Milena Ortiz and Cabrera, María Alexandra Ortiz},
	title = {Asymmetric sovereignty: Administrative Law facing the challenge of regulating the digital space; [Soberanía asimétrica: El derecho administrativo ante el desafío de regular el espacio digital]},
