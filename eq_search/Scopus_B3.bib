@BOOK{Ottmann202567,
	author = {Ottmann, Goetz and Brito, Iris Silva},
	title = {Automated algorithms, epistemological shifts, and the erosion of fundamental legal and ethical principles in the social services},
	year = {2025},
	journal = {AI and the Disruption of Welfare: Challenges for Social Work Education and Practice},
	pages = {67 - 79},
	doi = {10.4324/9781003673675-6},
	url = {https://www.scopus.com/pages/publications/105026325540?origin=resultslist},
	affiliations = {Federation University, Victoria, Australia; ACAP University College, Australia; Academia Grapiuna de Artes, Cultura and Letras, Itabuna-Ba, Brazil; Associação Beneficente Educação, Arte e Cidadania (AMBEC), Brazil},
	abstract = {Data-driven, Automated Algorithmic Decision-Making (AADM) in the human services is not only likely to transform social work practices; it also has the potential to displace current social work decisional authority and shift the ontological and epistemological foundations of the democratic welfare state. In this chapter, we are outlining how AADM can undermine the very basis of administrative law and with it the rights of service users anchored in a social democratic vision of accountability, transparency, fairness, due process, and legality. In doing so, it potentially unhinges the ontological and epistemological backdrop of the democratic welfare state, introducing concepts, language, meaning, logic, values, and premises that underpin software design and the reductionism of quantitative approaches to management. If left un-checked, AADM can turn service users into digital shadows defined by a myriad of data points that no longer hold rights to privacy, autonomy, or self-determination. This chapter argues that social work education needs to better prepare students for the complexities of digitally enabled statecraft and the biopolitics it enables, resulting all too often in oppression and harm. © 2026 selection and editorial matter, Goetz Ottmann and Carolyn Noble; individual chapters, the contributors.},
	keywords = {Decision making; Ethical technology; Ontology; Algorithmics; Automated algorithms; Data driven; Decisions makings; Ethical principles; Legal principles; Shift-and; Social service; Social work; Welfare state; Software design},
	publisher = {Taylor and Francis},
	isbn = {978-104045127-4; 978-103274112-3},
	language = {English},
	abbrev_source_title = {AI and the Disrupt. of Welf.: Challenges for Soc. Work Education and Practice},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Horvath2023,
	author = {Horvath, Laszlo and James, Oliver and Banducci, Susan and Beduschi, Ana},
	title = {Citizens' acceptance of artificial intelligence in public services: Evidence from a conjoint experiment about processing permit applications},
	year = {2023},
	journal = {Government Information Quarterly},
	volume = {40},
	number = {4},
	pages = {},
	doi = {10.1016/j.giq.2023.101876},
	url = {https://www.scopus.com/pages/publications/85175463381?origin=resultslist},
	affiliations = {School of Social Sciences, Birkbeck, University of London, Malet St, London, WC1E 7HX, United Kingdom; Department of Social and Political Sciences, Philosophy, and Anthropology, University of Exeter, Northcote House, The Queens Drive, Exeter Devon, EX4 4QJ, United Kingdom; Law School, University of Exeter, Northcote House, The Queens Drive, Exeter Devon, EX4 4QJ, United Kingdom},
	abstract = {Citizens' acceptance of artificial intelligence (AI) in public service delivery is important for its legitimate and effective use by government. Human involvement in AI systems has been suggested as a way to boost citizens' acceptance and perceptions of these systems' fairness. However, there is little empirical evidence to assess these claims. To address this gap, we conducted a pre-registered conjoint experiment in the UK regarding acceptance of AI in processing public permits: for immigration visas and parking permits. We hypothesise that greater human involvement boosts acceptance of AI in decision-making and associated perceptions of its fairness. We further hypothesise that greater human involvement mitigates the negative impact of certain AI features, such as inaccuracy, high cost, or data sharing. From our study, we find that more human involvement tends to increase acceptance, and that perceptions of fairness were less influenced. Yet, when substantial human discretion was introduced in parking permit scenarios, respondents preferred more limited human input. We found little evidence that human involvement moderates the impact of AI's unfavourable attributes. System-level factors such as high accuracy, the presence of an appeals system, increased transparency, reduced cost, non-sharing of data, and the absence of private company involvement all boost both acceptance and perceived procedural fairness. We find limited evidence that individual characteristics affect these results. The findings show how the design of AI systems can increase its acceptability to citizens for use in public services. © 2023 The Author(s)},
	author_keywords = {Artificial intelligence; Conjoint experiment; Human involvement; Public service},
	correspondence_address = {L. Horvath; London, 10 Gower Street, WC1E 6DP, United Kingdom; email: L.Horvath@bbk.ac.uk},
	publisher = {Elsevier Ltd},
	issn = {0740624X},
	coden = {GIQUE},
	language = {English},
	abbrev_source_title = {Gov. Inf. Q.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 47; All Open Access; Green Open Access; Hybrid Gold Open Access}
}

@ARTICLE{Ng20201041,
	author = {Ng, Yee-Fui and O’sullivan, Maria and Paterson, Moira and Witzleb, Normann},
	title = {Revitalising public law in a technological era: Rights, transparency and administrative justice},
	year = {2020},
	journal = {University of New South Wales Law Journal},
	volume = {43},
	number = {3},
	pages = {1041 - 1077},
	url = {https://www.scopus.com/pages/publications/85091349289?origin=resultslist},
	affiliations = {Faculty of Law, Castan Centre for Human Rights Law, Monash University, Australia},
	abstract = {This article examines how public law should be revitalised in light of the increasing use of technology in government decision-making. As the recent controversy concerning the implementation of an automated debt recovery system by the Department of Social Services illustrates, the automation of government decision-making engages fundamental legal principles such as transparency, procedural fairness and reviewability. The use of technology in administrative decision-making in Australia therefore raises a number of critical, and interlocking, questions: Is Australian public law fit for purpose to protect individual rights in automated governmental decision-making? If not, what reforms are necessary and how should they be instituted? This article will consider these issues in relation to three specific areas of public law: privacy law, freedom of information, and judicial review. In doing so, it sets out concrete recommendations for the revitalisation of Australian public law so that it may become more value-compliant and consistent with emerging international best practice standards. © 2020, University of New South Wales Law Journal. All rights reserved.},
	publisher = {University of New South Wales Law Journal},
	issn = {03130096},
	language = {English},
	abbrev_source_title = {Univ. New South Wales Law J.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 19}
}

@ARTICLE{Johari2026,
	author = {Johari, Bhavya},
	title = {Dual erosion of equality and remedy in algorithmic decision systems},
	year = {2026},
	journal = {Discover Artificial Intelligence},
	volume = {6},
	number = {1},
	pages = {},
	doi = {10.1007/s44163-026-01040-6},
	url = {https://www.scopus.com/pages/publications/105034196639?origin=resultslist},
	affiliations = {Jindal Global Law School, O. P. Jindal Global University, Sonipat, India},
	abstract = {This article develops a dual erosion framework demonstrating how Artificial Intelligence systems simultaneously undermine equality rights through discriminatory outcomes and obstruct effective remedies through opacity. Through comparative case synthesis spanning criminal justice algorithms in the United States and Canada, welfare eligibility systems in the European Union (EU) and India, credit scoring in Germany, employment screening, and content moderation, the analysis reveals that equality risk and remedy risk operate interdependently rather than in parallel. Biased algorithmic outputs become unreviewable due to opacity, while opacity enables bias to persist undetected. The article examines regulatory responses under the EU Artificial Intelligence Act, the Digital Services Act, and the revised Santa Clara Principles, proposing concrete implementation frameworks that include discovery protocols reconciling trade secrets with due process, burden-shifting standards adapted from employment discrimination law, risk-tiered due diligence requirements, independent audit mechanisms, and participatory governance models. These findings advance algorithmic accountability scholarship by providing adjudicable standards for courts and regulators, while demonstrating that comprehensive governance requires integrated approaches that address both equality and remedy dimensions. © The Author(s) 2026.},
	author_keywords = {Algorithmic accountability; Algorithmic transparency; Artificial intelligence governance; Digital rights regulation; Discrimination law; Due process rights; Effective remedy},
	keywords = {Artificial intelligence; Copyrights; Discriminators; Erosion; Government data processing; International law; Opacity; Algorithmic accountability; Algorithmic transparency; Algorithmics; Artificial intelligence governance; Digital right regulation; Digital rights; Discrimination law; Due process right; Effective remedy; Risk assessment},
	correspondence_address = {B. Johari; Jindal Global Law School, O. P. Jindal Global University, Sonipat, India; email: bhavya.johari@jgu.edu.in},
	publisher = {Springer Nature},
	issn = {27310809},
	language = {English},
	abbrev_source_title = {Discov. Artif. Intell.},
	type = {Article},
