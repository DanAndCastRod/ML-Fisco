@ARTICLE{Sever202525,
	author = {Sever, Tina},
	title = {Trends of Automated Decision-Making in the Public Sector},
	year = {2025},
	journal = {Governance and Public Management},
	volume = {Part F355},
	pages = {25 - 53},
	doi = {10.1007/978-3-031-81425-9_3},
	url = {https://www.scopus.com/pages/publications/105005442593?origin=resultslist},
	affiliations = {Faculty of Public Administration, University of Ljubljana, Ljubljana, Slovenia},
	abstract = {New trends in the public sector go toward introducing new technologies, with goals to improve its services and decision-making. However, the public sector is still not fully exploiting the potential of new technologies. This is of no surprise, since it has limited resources and a very rigid and formal system bound by law. Due to the lack of resources, development of new solutions is outsourced, which can affect transparency and functionality of such solutions, raise questions on post-launch services, and establish overall dependency on the developers of these solutions, who sometimes even invoke intellectual property protection and do not want to reveal data on the functioning of the systems. Furthermore, the problem with fast technological development nowadays is that legislation lags behind it. Consequently, there is a lack of legislation or it becomes obsolete. When introducing new technologies the theory encourages human-centric approaches, giving the power of technology to the people. AI design should be sustainable and produce tools and applications that are ethical, safe, well-founded, and transparent. The chapter focuses on automated decision-making (ADM) in public sector. We found different examples of existing administrative fields in Finland, Sweden, Estonia, and Slovenia, where at least some parts of the processes are left to ADM, which is regulated. Namely, administrative law on a national level should also tackle ADM and enable legality, procedural fairness, transparency, and accountability. Finally, this chapter gives some insights on ADM challenges and solutions in public sector. © The Editor(s) (if applicable) and The Author(s), under exclusive license to Springer Nature Switzerland AG 2025.},
	author_keywords = {Automated decision-making; Human-centric AI design; Public sector innovation; Public sector technology},
	correspondence_address = {T. Sever; Faculty of Public Administration, University of Ljubljana, Ljubljana, Slovenia; email: tina.sever@fu.uni-lj.si},
	publisher = {Palgrave Macmillan},
	issn = {2524728X},
	language = {English},
	abbrev_source_title = {Gov. Public. Manag.},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 3}
}

@ARTICLE{Pagallo2018507,
	author = {Pagallo, Ugo},
	title = {Algo-Rhythms and the Beat of the Legal Drum},
	year = {2018},
	journal = {Philosophy and Technology},
	volume = {31},
	number = {4},
	pages = {507 - 524},
	doi = {10.1007/s13347-017-0277-z},
	url = {https://www.scopus.com/pages/publications/85059566070?origin=resultslist},
	affiliations = {Law School, University of Torino, Lungo Dora Siena 100 A, Torino, 10153, Italy},
	abstract = {The paper focuses on concerns and legal challenges brought on by the use of algorithms. A particular class of algorithms that augment or replace analysis and decision-making by humans, i.e. data analytics and machine learning, is under scrutiny. Taking into account Balkin’s work on “the laws of an algorithmic society”, attention is drawn to obligations of transparency, matters of due process, and accountability. This US-centric analysis on drawbacks and loopholes of current legal systems is complemented with the analysis of norms and principles of the EU data protection law, or “GDPR”. The aim is twofold. On the one hand, the intent is to shed light on some crucial differences between the US and EU law on the regulation of algorithmic operators, both public and private. Whereas, in the USA, scholars debate whether and to what extent new duties and responsibilities of algorithmic operators, e.g. information fiduciaries, have to amend the current framework of self-regulation and light government—as shown by the White House’s Office of Science and Technology Policy report from November 2016—in EU law much of the new duties and responsibilities of algorithmic operators have been passed upon them as data controllers. Whether such approaches will successfully tackle the normative challenges of the algorithmic society is, on the other hand, an open issue that will likely represent the main topic of debate over the next years. Disagreement may concern: (i) the terms framing the legal question in e.g. statistical purposes of the data processing; (ii) how such terms are related to each other in legal reasoning (e.g. a right to explanation as valid law in the EU); and (iii) legal hard cases that will increasingly have to do with the principles that are at stake also but not only in data protection (e.g. informational self-determination). By entrusting such legal hard cases to algorithms, or some sort of smart artificial agent, humans still bear full responsibility for the judgment of what is socially, ethically, and legally “plain” and “hard” in social affairs. The balance between delegation of decisions to algorithms and non-delegation will be the leitmotiv of the algorithmic society. Since the devil is in the detail, the current paper is devoted to some of them. © 2017, Springer Science+Business Media B.V.},
	author_keywords = {Algorithm; Algorithmic society; Data protection law; Legal hard case; Right to explanation; Technological convergence},
	correspondence_address = {U. Pagallo; Law School, University of Torino, Torino, Lungo Dora Siena 100 A, 10153, Italy; email: ugo.pagallo@unito.it},
	publisher = {Springer Netherlands},
	issn = {22105433},
	language = {English},
	abbrev_source_title = {Philos. Technol.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 30; All Open Access; Green Open Access}
}

@ARTICLE{Frosio20181,
	author = {Frosio, Giancarlo F.},
	title = {Why keep a dog and bark yourself? From intermediary liability to responsibility},
	year = {2018},
	journal = {International Journal of Law and Information Technology},
	volume = {26},
	number = {1},
	pages = {1 - 33},
	doi = {10.1093/ijlit/eax021},
	url = {https://www.scopus.com/pages/publications/85041050850?origin=resultslist},
	affiliations = {Center for International Intellectual Property Studies (CEIPI), Universitè de Strasbourg, France; Stanford Law School, Center for Internet and Society, United States; Duke University School of Law, Durham, NC, United States; Strathclyde University, Glasgow, United Kingdom; Università Cattolica del Sacro Cuore, Milan, Italy},
	abstract = {This article contextualizes the recent developments in intermediary liability theory and policy within a broader move towards private ordering online. In this context, online intermediaries' governance would move away from a well-established utilitarian approach and towards a moral approach by rejecting negligence-based intermediary liability arrangements. Miscellaneous policy tools-such as monitoring and filtering obligations, blocking orders, graduated response, payment blockades and follow-the-money strategies, private Domain Name System content regulation, online search manipulation, or administrative enforcement-might reflect this change in perspective. In particular, policy makers-and interested third-parties such as intellectual property rightholders-try to coerce online intermediaries into implementing these policy strategies through voluntary measures and self-regulation, in addition to validly enacted obligations. This process might be pushing an amorphous notion of responsibility that incentivizes intermediaries' self-intervention to police allegedly infringing activities in the Internet. In this sense, the intermediary liability discourse is shifting towards an intermediary responsibility discourse. Furthermore, enforcement would be looking once again for an 'answer to the machine in the machine'. By enlisting online intermediaries as watchdogs, governments would de facto delegate online enforcement to algorithmic tools. Due process and fundamental guarantees get mauled by technological enforcement, curbing fair uses of content online and silencing speech according to the mainstream ethical discourse. © The Author (2017). Published by Oxford University Press. All rights reserved.},
	author_keywords = {Copyright; Defamation; Enforcement; Free speech; Intellectual property; Intermediary liability; Internet governance; Platforms},
	correspondence_address = {G.F. Frosio; Center for International Intellectual Property Studies (CEIPI), Universitè de Strasbourg, France; email: gcfrosio@ceipi.edu},
	publisher = {Oxford University Press},
	issn = {09670769},
	language = {English},
	abbrev_source_title = {Int. J. Law Inf. Technol.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 41}
}

