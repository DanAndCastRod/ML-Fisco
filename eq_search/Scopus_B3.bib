@ARTICLE{Molitoris2025120,
	author = {Molitoris, Peter},
	title = {LIMITS OF THE USE OF ARTIFICIAL INTELLIGENCE IN THE ALTERNATIVE RESOLUTION OF ADMINISTRATIVE DISPUTES1; [LIMITY VYUŽITIA UMELEJ INTELIGENCIE V ALTERNATÍVNOM RIEŠENÍ SPRÁVNYCH SPOROV]},
	year = {2025},
