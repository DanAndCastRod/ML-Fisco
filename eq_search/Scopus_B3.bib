@BOOK{Spaulding2023251,
	author = {Spaulding, Norman W.},
	title = {Online Dispute Resolution and the End of Adversarial Justice?},
	year = {2023},
	journal = {Legal Tech and the Future of Civil Justice},
	pages = {251 - 285},
	doi = {10.1017/9781009255301.015},
	url = {https://www.scopus.com/pages/publications/105026517421?origin=resultslist},
	affiliations = {Stanford Law School, United States},
	abstract = {Although proponents of online dispute resolution systems proclaim that their innovations will expand access to justice for so-called "simple cases," evidence of how the technology actually operates and who is benefitting from it demonstrates just the opposite. Resolution of some disputes may be more expeditious and user interface more intuitive. But in order to achieve this, parties generally do not receive meaningful information about their rights and defenses. The opacity of the technology (ODR code is not public and unlike court appearance its proceedings are private) means that due process defects and systemic biases are difficult to identify and address. Worse still, the "simple cases" argument for ODR assumes that the dollar value of a dispute is a reasonable proxy for its complexity and significance to the parties. This assumption is contradicted by well established research on procedural justice. Moreover, recent empirical studies show that low money value cases, which dominate state court dockets, are for the most part debt collection proceedings brought by well-represented private creditors or public creditors (including courts themselves, which increasingly depend on fines and fees for their operating budget). Defendants in these proceedings are overwhelmingly unrepresented individuals. What ODR offers in these settings is not access to justice for ordinary people, but rather a powerful accelerated collection and compliance technology for private creditors and the state. This chapter examines the design features of ODR and connects them to the ideology of tech evangelism that drives deregulation and market capture, the aspirations of the alternative dispute resolution movement, and hostility to the adversary system that has made strange bedfellows of traditional proponents of access to justice and tech profiteers. The chapter closes with an analysis of front-end standards for courts and bar regulators to consider to ensure that technology marketed in the name of access to justice actually serves the legal needs of ordinary people. © Cambridge University Press & Assessment 2023. All rights reserved.},
	author_keywords = {Access to justice; ADR; Algorithmic governance; Alternative dispute resolution; Artificial intelligence; Dispute systems design; Disruptive innovation; ODR; Online Dispute Resolution; Predictive analytics; Preventive justice; Procedural justice},
	keywords = {Behavioral research; Budget control; Commerce; Deregulation; Government data processing; Online systems; Predictive analytics; Systems analysis; Access to justice; ADR; Algorithmic governance; Algorithmics; Alternative dispute resolution; Dispute system design; Disruptive innovations; ODR; Online dispute resolution; Preventive justice; Procedural justice; Artificial intelligence},
	publisher = {Cambridge University Press},
	isbn = {978-100925530-1; 978-100925535-6},
	language = {English},
	abbrev_source_title = {Legal Tech and the Futur. of Civ. Justice},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 4; All Open Access; Bronze Open Access}
}

