@ARTICLE{Greene2022S692,
	author = {Greene, Travis and Shmueli, Galit and Fell, Jan and Lin, Ching-Fu and Liu, Han-Wei},
	title = {Forks over knives: Predictive inconsistency in criminal justice algorithmic risk assessment tools},
	year = {2022},
	journal = {Journal of the Royal Statistical Society. Series A: Statistics in Society},
	volume = {185},
	number = {S2},
	pages = {S692 - S723},
	doi = {10.1111/rssa.12966},
	url = {https://www.scopus.com/pages/publications/85143385534?origin=resultslist},
	affiliations = {Institute of Service Science, National Tsing Hua University, Hsinchu, Taiwan; Institute of Law for Science and Technology, National Tsing Hua University, Hsinchu, Taiwan; Department of Business Law and Taxation, Monash University, Clayton, VIC, Australia},
	abstract = {Big data and algorithmic risk prediction tools promise to improve criminal justice systems by reducing human biases and inconsistencies in decision-making. Yet different, equally justifiable choices when developing, testing and deploying these socio-technical tools can lead to disparate predicted risk scores for the same individual. Synthesising diverse perspectives from machine learning, statistics, sociology, criminology, law, philosophy and economics, we conceptualise this phenomenon as predictive inconsistency. We describe sources of predictive inconsistency at different stages of algorithmic risk assessment tool development and deployment and consider how future technological developments may amplify predictive inconsistency. We argue, however, that in a diverse and pluralistic society we should not expect to completely eliminate predictive inconsistency. Instead, to bolster the legal, political and scientific legitimacy of algorithmic risk prediction tools, we propose identifying and documenting relevant and reasonable ‘forking paths’ to enable quantifiable, reproducible multiverse and specification curve analyses of predictive inconsistency at the individual level. © 2022 Royal Statistical Society.},
	author_keywords = {algorithmic risk prediction; criminal justice; forking paths; multiverse analysis; pluralism; predictive inconsistency; specification curve analysis},
	correspondence_address = {T. Greene; Institute of Service Science, National Tsing Hua University, Hsinchu, Taiwan; email: travis.greene@iss.nthu.edu.tw},
	publisher = {John Wiley and Sons Inc},
	issn = {09641998},
	language = {English},
	abbrev_source_title = {J. R. Stat. Soc. Ser. A Stat. Soc.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2; All Open Access; Green Open Access}
}

