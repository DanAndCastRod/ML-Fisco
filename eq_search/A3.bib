	language = {English},
	abbrev_source_title = {Corporate Compliance on a Global Scale: Legitimacy and Effectiveness},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@CONFERENCE{Mujiyana2025,
