	author = {Hanson, Mathias and Lewkowicz, Gregory and Verboven, Sam},
	title = {Engineering the law-machine learning translation problem: developing legally aligned models},
	year = {2026},
	journal = {Computer Law and Security Review},
	volume = {60},
	pages = {},
	doi = {10.1016/j.clsr.2025.106252},
	url = {https://www.scopus.com/pages/publications/105035010653?origin=resultslist},
	affiliations = {Vrije Universiteit Brussel, Data Lab, Pleinlaan 2, Brussels, 1050, Belgium; Université Libre de Bruxelles - Smart Law Hub, Avenue Franklin Roosevelt 50, Brussels, 1050, Belgium; FARI - AI for the Common Good Institute, Cantersteen 10/12, Brussels, 1000, Belgium},
	abstract = {Organizations developing machine learning-based (ML) technologies face the complex challenge of achieving high predictive performance while respecting the law. This intersection between ML and the law creates new complexities. As ML model behavior is inferred from training data, legal obligations cannot be operationalized in source code directly. Rather, legal obligations require "indirect" operationalization. However, choosing context-appropriate operationalizations presents two compounding challenges: (1) laws often permit multiple valid operationalizations for a given legal obligation—each with varying degrees of legal adequacy; and, (2) each operationalization creates unpredictable trade-offs among the different legal obligations and with predictive performance. Evaluating these trade-offs requires metrics (or heuristics), which are in turn difficult to validate against legal obligations. Current methodologies fail to fully address these interwoven challenges as they either focus on legal compliance for traditional software or on ML model development without adequately considering legal complexities. In response, we introduce a five-stage interdisciplinary framework that integrates legal and ML-technical analysis during ML model development. This framework facilitates designing ML models in a legally aligned way and identifying high-performing models that are legally justifiable. Legal reasoning guides choices for operationalizations and evaluation metrics, while ML experts ensure technical feasibility, performance optimization and an accurate interpretation of metric values. This framework bridges the gap between more conceptual analysis of law and ML models’ need for deterministic specifications. We illustrate its application using a case study in the context of anti-money laundering. © 2025},
	author_keywords = {Anti-money laundering; Artificial intelligence; Human-centric AI; Legal risk management, AI governance; Machine learning; Regulatory compliance},
	keywords = {Commerce; Learning systems; Machine learning; Risk management; Anti-money laundering; Human-centric; Human-centric AI; Learning Based Models; Legal obligations; Legal risk management; Legal risk management, AI governance; Machine-learning; Predictive performance; Trade off; Economic and social effects; Regulatory compliance},
	correspondence_address = {M. Hanson; Brussels, Pleinlaan 5, 4th floor, 1050, Belgium; email: mathias.hanson@vub.be},
