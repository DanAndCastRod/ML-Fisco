}

@ARTICLE{Lévesque202533,
	author = {Lévesque, Maroussia},
	title = {SMOKE AND MIRRORS? CORPORATE DISCRETION IN AI REGULATION},
	year = {2025},
	journal = {Journal of Law, Technology and Policy},
	volume = {2025},
	number = {1},
	pages = {33 - 118},
	url = {https://www.scopus.com/pages/publications/105009509893?origin=resultslist},
	affiliations = {Harvard Law School, United States},
	abstract = {Who is in the driver’s seat of AI governance? In short, a handful of entrenched market players. AI regulation typically brings in regulated entities as joint-problem solvers with governments supposed to steer, not row. This approach makes sense in light of AI’s fast-moving complexity, yet it also masks the far-reaching discretion of regulated firms. As AI generates deepfakes, upends education and perniciously discriminates, do we really want profit driven AI companies to make the rules? Significant leeway for corporations making and using AI is a recurring pattern across jurisdictions. It allows them to override the public interest with their own agenda: secure and maintain a competitive advantage. This latitude is a problem because it deprives the polity of agency over a crucial technology affecting multiple and important aspects of society. Probing AI regulation initiatives in the EU, the US, and Canada surfaces similarities and differences regarding firm discretion. Industry players often dominate nominally collaborative governance processes so as to effectively decide the rules that apply to their activities. Management-based approaches to compliance also give companies significant latitude to interpret and implement rules as they see fit. At the end of the day, firms are essentially grading their own homework. Enforcement is where the three jurisdictions part ways. When the rubber meets the road, AI regulation is only as effective as the ability to enforce rules— especially when firms are given so much range in making and applying them. The EU stands out as a promising model, with several layers of oversight and innovative ways to enlist private third-party expertise. American enforcement is more uncertain, and commercialization pressures undermine the Canadian model. Policymakers must reckon with industry capture. This capture takes various forms like dominating the process for setting technical standards; loading the dice in favor of lenient compliance measures; and subtler distortions when firms interpret regulation through their own organizational logics. Ultimately, policymakers must confront defeatist narratives whereby incompetent governments should just step aside and defer to all-knowing industry stakeholders. Instead, they should muster the ambition and confidence to step into their role as stewards of the public good. © 2025, University of Illinois College of Law. All rights reserved.},
	publisher = {University of Illinois College of Law},
	issn = {15301931},
	language = {English},
	abbrev_source_title = {J. Law Technol. Policy},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Brüggen2025436,
	author = {Brüggen, Lisa and Gianni, Robert and de Haan, Floris and Hogreve, Jens and Meacham, Darian and Post, Thomas and van der Werf, Minou},
	title = {AI-Based Financial Advice: An Ethical Discourse on AI-Based Financial Advice and Ethical Reflection Framework},
