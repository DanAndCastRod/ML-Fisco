@BOOK{Abramovitz202511,
	author = {Abramovitz, Mimi and Zelnick, Jennifer},
	title = {Managerialism on steroids: The rise of Artificial Intelligence},
	year = {2025},
	journal = {AI and the Disruption of Welfare: Challenges for Social Work Education and Practice},
	pages = {11 - 28},
	doi = {10.4324/9781003673675-2},
	url = {https://www.scopus.com/pages/publications/105026326473?origin=resultslist},
	abstract = {Over the past few decades, Neoliberal policies and practices—including spending cuts, tax cuts, privatization, and assaults on social movements—have profoundly restructured human services in the United States and Western Europe. Managerialism, defined as the imposition of market logics, business principles, and performance metrics onto human service organizations, has transformed the provision of care. Managerialism encourages workers to internalize the business-driven “logic of the market” over the mission-driven “logic of social work” while downplaying the ideals of equality, common good, and social justice. Amplifying the impact of Managerialism, Artificial Intelligence (AI) purports to introduce neutral, technological advances. Yet increasingly commercialized AI tools have intensified Managerialist pressures for productivity, efficiency, and quantification while simultaneously reshaping service provision and labor processes. AI systems automate complex human tasks, reduce the need for direct human input in ways that undermine professional judgment, clinical reasoning, and relational skills central to ethical practice and policy. AI’s opaque algorithmic decision-making processes that make it difficult for workers, service users, and the public to understand agency decisions also obscure lines of accountability and transparency. Finally, AI contributes to the surveillance, deskilling, and the displacement of workers. Rather than enhance fairness, AI often amplifies structural biases, further marginalizing vulnerable populations. Still in its development stage, the impact of AI depends on how well humans design, implement, and govern the new technology. With the help of ethical governance, diverse representation, and a heavy dose of human oversight, society may be able to convert AI from a threat to an instrument for human progress. © 2026 selection and editorial matter, Goetz Ottmann and Carolyn Noble; individual chapters, the contributors.},
	keywords = {Commerce; Decision making; Ethical technology; Human resource management; Taxation; Business performance; Business principles; Human services; Mission-driven; Performance metrices; Service organizations; Social movements; Tax cuts; Western Europe; Workers'; Artificial intelligence},
	publisher = {Taylor and Francis},
	isbn = {978-104045127-4; 978-103274112-3},
	language = {English},
	abbrev_source_title = {AI and the Disrupt. of Welf.: Challenges for Soc. Work Education and Practice},
	type = {Book chapter},
	publication_stage = {Final},
