	author = {Zhou, Yanqiu and Chen, Lei and Zhou, Xu and Hu, Shihua},
	title = {Key factors and path selection for enterprise digital transformation: configuration analysis based on fsQCA},
	year = {2024},
	journal = {Frontiers in Sustainability},
	volume = {5},
	pages = {},
	doi = {10.3389/frsus.2024.1366129},
	url = {https://www.scopus.com/pages/publications/85201188850?origin=resultslist},
	affiliations = {School of Economics and Management, Tsinghua University, Beijing, China; Institute for State-Owned Enterprises, Tsinghua University, Beijing, China; School of Finance and Taxation, Capital University of Economics and Business, Beijing, China; School of Finance and Taxation, Inner Mongolia University of Finance and Economics, Hohhot, China; Thinkingbiomed (Beijing) Co. Ltd, Beijing, China},
	abstract = {The new digital technology revolution is spurring corporate digital transformation. Presently, the majority of enterprises are still in the digitalization stage. They have yet to pinpoint the key factors and suitable paths for their transformation. Therefore, this study aims to determine which and how factors affect this transformation to improve the current enterprise's digital transformation. We extract key elements affecting corporate digital transformation. Taking 98 representative businesses as examples, we utilize the fuzzy-set qualitative comparative analysis approach (fsQCA) to investigate how different factors combine to achieve digital transformation. The results show that: (1) No single factor can achieve digital transformation for enterprises, as it requires a combination of multiple factors. (2) Four configuration paths can lead to corporate digital transformation. (3) A business can equivalently substitute resource consolidation with strategic planning and human resources to drive digital transformation. This study offers multiple paths for achieving corporate digital transformation to guide businesses in their choice of digital transformation pathways. Copyright © 2024 Zhou, Chen, Zhou and Hu.},
	author_keywords = {digital economy; digital transformation; fsQCA; organizational response; technological shock},
