	affiliations = {Maynooth University School of Business, Ireland; CONNECT, Research Ireland Centre for Future Networks and Communications, Ireland; J.E. Cairnes School of Business and Economics, University of Galway, Ireland; University’s Tax Clinic, Australia; Data Science Institute, University of Galway, Ireland; School of Public Policy and Administration, Carleton University, Canada; Maynooth University School of Business, Ireland; CONNECT, Research Ireland Centre for Future Networks and Communications, Ireland},
