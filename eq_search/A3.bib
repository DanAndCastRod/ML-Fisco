@BOOK{Tombal2023111,
	author = {Tombal, T. and Willem, P. and De Terwangne, C.},
	title = {Legal framework for the use of big data and blockchain in public governance},
	year = {2023},
	journal = {The New Digital Era Governance: How New Digital Technologies are Shaping Public Governance},
	pages = {111 - 140},
	doi = {10.3920/978-90-8686-930-5_4},
	url = {https://www.scopus.com/pages/publications/105026324818?origin=resultslist},
	affiliations = {Faculty of Law, University of Namur, Rempart de la Vierge, 5, Namur, 5000, Belgium; Tilburg Institute for Law and Technology, Tilburg University, Prof. Cobbenhagenlaan 221, Tilburg, 5037DE, Netherlands; Centre de recherche Information, Droit et Société, Namur Digital Institute, University of Namur, Rempart de la Vierge, 5, Namur, 5000, Belgium},
	abstract = {By using technologies, such as big data and blockchain, public administrations are able to process a large amount of citizens’ personal data. When processing these personal data, the administration must comply with the personal data protection rules contained in the General Data Protection Regulation. As the use of such technologies could have dramatic impacts on the lives of their citizens, it is fundamental to understand the limits that this legal framework puts on their use. This chapter analyses the interactions between personal data protection and big data and blockchain technologies. It explains the legal framework within which such technologies can be leveraged by public administrations for the provision of their public services. Focussing on data collection and combination (big data), this chapter concludes that the processing of personal should be based on a law meeting certain requirements. Data subjects’ rights must also be respected. Regarding data storage (blockchain), several key and concrete takeaways are formulated for public administrations. While most of the following analysis will be equally applicable to any public administration within the European Union, this chapter will focus on two case studies within the Belgian public administration, namely the public policies and decision-making linked to social security infringements and tax fraud at the Belgian federal level. Indeed, these could have a significant impact on citizens’ finances in particular, and their lives in general. © Wageningen Academic Publishers The Netherlands, 2022.},
	author_keywords = {Big data; Blockchain; Fraud; GDPR; Public administration},
	keywords = {Crime; Digital storage; Public administration; Security of data; Taxation; Block-chain; Data collection; Data combination; Fraud; GDPR; General data protection regulations; Large amounts; Legal frameworks; Personal data protections; Public services; Big data},
	publisher = {Brill},
	isbn = {978-908686930-5; 978-908686378-5},
	language = {English},
	abbrev_source_title = {The New Digital Era Gov.: How New Digital Technologies are Shap. Public Gov.},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Haesevoets2026,
	author = {Haesevoets, Tessa and Verschuere, Bram and Van Hiel, Alain and Roets, Arne},
	title = {Public servants' attitudes toward the use of Artificial Intelligence in policymaking: An experimental study},
	year = {2026},
	journal = {Government Information Quarterly},
	volume = {43},
	number = {2},
	pages = {},
	doi = {10.1016/j.giq.2026.102134},
	url = {https://www.scopus.com/pages/publications/105032762599?origin=resultslist},
	affiliations = {Department of Public Governance and Management, Ghent University, Belgium; Department of Developmental, Personality and Social Psychology, Ghent University, Belgium},
	abstract = {Artificial Intelligence (AI) is becoming increasingly integrated into various aspects of society, including public policy processes. However, little is known about public servants' views on the use and implementation of AI. We conducted an experimental study among UK public servants ( N = 801) to examine how attitudes toward different levels of AI involvement vary across the phases of the policy cycle and how the provision of information influences these attitudes. Our findings are threefold. First, we observed significant skepticism toward more extensive forms of AI involvement. That is, public servants' attitudes became less favorable as AI's role and/or weight in policymaking increased, particularly when AI moved beyond providing advice and support. Secondly, attitudes toward AI involvement were least positive during the policy decision-making phase, whereas AI involvement in the policy evaluation phase was viewed most positively. Thirdly, public servants who received information about AI's potential applications expressed more positive attitudes than those who did not receive such information. In sum, the present study demonstrates a cautious attitude among public servants toward deeper AI integration in public policy processes, which can at least partly be improved through targeted information about AI's potential applications. © 2026 Elsevier Inc.},
	author_keywords = {Artificial Intelligence (AI); Experimental study; Information availability; Levels of AI involvement, policymaking cycle; Public servants},
	correspondence_address = {T. Haesevoets; Department of Public Governance and Management, Faculty of Economics and Business Administration, Ghent University, Gent, Campus UFO, St.-Pietersnieuwstraat 33, 9000, Belgium; email: tessa.haesevoets@ugent.be},
	publisher = {Elsevier Ltd},
	issn = {0740624X},
	coden = {GIQUE},
	language = {English},
	abbrev_source_title = {Gov. Inf. Q.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Motzfeldt2018135,
	author = {Motzfeldt, Hanne Marie and Næsborg-Andersen, Ayo},
	title = {Digitalisation and the (Unintended) illegal outsourcing of legislative and administrative power in Denmark},
	year = {2018},
	journal = {Proceedings of the European Conference on e-Government, ECEG},
	volume = {2018-October},
	pages = {135 - 141},
	url = {https://www.scopus.com/pages/publications/85059284407?origin=resultslist},
	affiliations = {Aarhus University, Aarhus, Denmark; University of Southern Denmark, Odense, Denmark},
	abstract = {Denmark is far ahead in developing Digital Government. The digital infrastructure is highly developed. Automated decision-making is used on a growing scale within the areas of tax, environmental regulation and welfare. In some narrow and defined areas AI is integrated. This is not without issues, as challenges have emerged. One of these challenges is a loss of insight by the public authorities into the formation of decisions directed at citizens. This is mainly due to the outsourcing of the development and maintenance of the used technologies. As an example, the Minister of Taxation in 2014 reported to the national Parliament that the tax authorities had lost the insight into, as well as the control of, more than 200 systems used within this area of administration. Only the private suppliers of those systems possessed the knowledge necessary to describe and change the functionalities and digital decision-making. Therefore, to a certain extent power of decision-making had – unofficially – been outsourced to private suppliers. This unwanted side effect of digitalisation was, however, counteracted by the Danish Ombudsman in a recent case concerning one of the core Danish digital infrastructure components (the national NemID). In the summer of 2017 the Ombudsman stated that if private companies were to develop and operate such critical digital infrastructure, the explicit acceptance of the democratically legitimised parliament was required. This applies, even though a public procurement procedure has been performed legally correct per the Ombudsman. This paper will focus on this challenges caused by digitalisation of the public sector, the disruption of the allocation of administrative and legislative power in the national constitution. An argument will be developed through an examination of both recent literature as well as case-law from the Danish Parliamentary Ombudsman, ultimately resulting in a presentation of the current Danish solution to the challenges described above – which hopefully can inspire and serve as an input to a discussion of the relationship between private suppliers of digital services and public authorities at a European level. © 2018, Academic Conferences Limited. All rights reserved.},
	author_keywords = {Administrative law; Delegation of powers; Democratic legitimacy; Digital Government; Outsourcing},
	keywords = {Environmental regulations; Laws and legislation; Outsourcing; Taxation; Administrative law; Automated decision making; Delegation of powers; Democratic legitimacies; Digital government; Digital infrastructures; Public authorities; Public procurement; Decision making},
	editor = {Ramos A.C. and Bouzas-Lorenzo R.},
	publisher = {Academic Conferences Limited},
	issn = {20491034},
	isbn = {978-191276403-7},
	language = {English},
	abbrev_source_title = {Proc. European Conf. on e-Gov., ECEG},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2}
}

@BOOK{Chesterman20211,
	author = {Chesterman, Simon},
	title = {We, The Robots?: Regulating Artificial Intelligence And The Limits Of The Law},
	year = {2021},
	journal = {We, the Robots?: Regulating Artificial Intelligence and the Limits of the Law},
	pages = {1 - 290},
	doi = {10.1017/9781009047081},
	url = {https://www.scopus.com/pages/publications/105024368691?origin=resultslist},
	affiliations = {National University of Singapore, Singapore},
	abstract = {Should we regulate artificial intelligence? Can we? From self-driving cars and high-speed trading to algorithmic decision-making, the way we live, work, and play is increasingly dependent on AI systems that operate with diminishing human intervention. These fast, autonomous, and opaque machines offer great benefits – and pose significant risks. This book examines how our laws are dealing with AI, as well as what additional rules and institutions are needed – including the role that AI might play in regulating itself. Drawing on diverse technologies and examples from around the world, the book offers lessons on how to manage risk, draw red lines, and preserve the legitimacy of public authority. Though the prospect of AI pushing beyond the limits of the law may seem remote, these measures are useful now – and will be essential if it ever does. © Simon Chesterman 2021.},
	keywords = {Intelligent robots; AI systems; Algorithmics; Decisions makings; High Speed; Human intervention; Public authorities; Red line; Self drivings; Decision making},
	publisher = {Cambridge University Press},
	isbn = {978-100904708-1; 978-131651768-0},
	language = {English},
	abbrev_source_title = {We, the Robots?: Regulating Artificial Intelligence and the Limits of the Law},
	type = {Book},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 92}
}

