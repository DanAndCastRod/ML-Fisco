	affiliations = {School of Management and Entrepreneurship, Indian Institute of Technology, Rajasthan, Jodhpur, 342030, India; Prestige Institute of Management and Research Gwalior, Madhya Pradesh, 474003, India},
	abstract = {In an increasingly digitalized world, the digitalization of government services has become a key indicator of a country's progress toward sustainable development. It reflects the extent to which digital transformation enhances governments' ability to modernize public administration, deliver efficient services, ensure transparency, and foster civic engagement. The present study investigates the distributional effects of digital governance on natural resource efficiency, relying on a theoretical framework and an empirical approach based on panel data covering 178 economies over the period 2003-2022. The results show that digital governance significantly improves natural resource efficiency. Specifically, a one percent increase in digital governance is associated with substantial reductions in natural resource depletion and energy intensity, by up to 25.31 and 8.35 units, respectively, at higher quantiles of the distribution. Moreover, digital governance positively affects the agricultural orientation index and access to clean fuel technologies, with increases of up to 1.76 units and 0.05 percent, respectively. These effects are primarily driven by improvements in government digital services, which constitute a key dimension of effective governance and administration. Finally, enhanced access to electricity supports more efficient energy use and contributes to reducing natural resource depletion, thereby promoting sustainable practices. © 2026 CEPII (Centre d'Etudes Prospectives et d'Informations Internationales), a center for research and expertise on the world economy},
	author_keywords = {Clean fuels; Digital governance; Energy intensity; Global decarbonization strategies; Governance efficiency},
