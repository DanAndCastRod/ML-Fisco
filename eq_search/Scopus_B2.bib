	abbrev_source_title = {Multidiscip. Rev.},
	type = {Review},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1; All Open Access; Gold Open Access}
}

@ARTICLE{Araujo2025145127,
