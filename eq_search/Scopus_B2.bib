	title = {The Impact of the Bosco Case: An Evolutionary and Critical Analysis of a Ruling that Consolidates Algorithmic Transparency in a Context of Recognition of Social Rights and Vulnerability; [El impacto del Caso Bosco: Análisis evolutivo y crítico de un pronunciamiento que consolida la transparencia algorítmica, en un contexto de reconocimiento de derechos sociales y vulnerabilidad]},
	year = {2025},
	journal = {Ius et Veritas},
