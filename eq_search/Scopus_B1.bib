@CONFERENCE{Herwanto2025,
	author = {Herwanto, Teguh and Haris, Muhammad},
	title = {Selecting Corporate Taxpayer Audit Candidates: a Tabnet-Based Semi-Supervised Learning Approach with Undersampling},
	year = {2025},
	journal = {Proceeding - 2025 International Conference on Information Technology Research and Innovation: Harnessing Intelligent Machines for Sustainable Development: Aligning AI with the SDGs, ICITRI 2025},
	pages = {},
	doi = {10.1109/ICITRI67507.2025.11232915},
	url = {https://www.scopus.com/pages/publications/105029552373?origin=resultslist},
	affiliations = {Computer Science Universitas Nusa Mandiri, Jakarta, Indonesia},
	abstract = {This paper introduces a semi-supervised learning approach to optimize corporate tax audit candidate selection using a sensitive, real-world dataset of 47,072 taxpayer records, with only 5.7 % positive audit cases. By integrating feature selection, random undersampling, and the TabNet architecture, our method effectively leverages both labeled and unlabeled data to address class imbalance and scarcity of positive labels. Experiments demonstrate a recall of 0.956 on the test set, surpassing LightGBM (0.721) and artificial neural networks (0.667), thus improving the identification of potential audit cases while maintaining an optimal false positive rate. The main contribution is the practical integration of these techniques for audit selection in operational environments, validated on a large-scale, sensitive dataset that reflects the real-world challenge of limited positive cases.  © 2025 IEEE.},
	author_keywords = {Class imbalance; random undersampling; semi-supervised learning; TabNet; tax audit lead selection},
	keywords = {Labeled data; Large datasets; Learning algorithms; Self-supervised learning; Semi-supervised learning; Taxation; Candidate selection; Class imbalance; Corporates; Lead selection; Random under samplings; Semi-supervised learning; Supervised learning approaches; Tabnet; Tax audit lead selection; Under-sampling; Neural networks},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {979-833156940-2},
	language = {English},
	abbrev_source_title = {Proceeding - Int. Conf. Inf. Technol. Res. Innov.: Harnessing Intell. Mach. Sustain. Dev.: Aligning AI SDGs, ICITRI},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Kumar2025,
	author = {Kumar, Uttam and Kumar, Arunoday and Kumar, Akash and Sathiyasuntharam, V.},
	title = {Income Tax Fraud Detection System Using AI and Machine Learning},
	year = {2025},
	journal = {2025 International Conference on Computing and Communications, COMPUTINGCON 2025},
	pages = {},
	doi = {10.1109/COMPUTINGCON64838.2025.11379714},
	url = {https://www.scopus.com/pages/publications/105035534523?origin=resultslist},
	affiliations = {Sharda University, Department of Computer Science and Engineering, Greater Noida, India},
	abstract = {Income tax fraud poses a significant threat to the financial integrity of nations, undermining revenue collection and public trust in fiscal systems. Manual auditing methods are often insufficient to detect sophisticated and evolving patterns of tax evasion in a timely manner. Recent advancements in data-driven technologies have led to the development of machine learning and artificial intelligence-based models for fraud detection. These solutions have demonstrated potential in identifying anomalous patterns in transactional and taxpayer behavior using historical and behavioral data. However, most existing models struggle with imbalanced datasets, limited interpretability, and real-time adaptability. This study proposes a robust AI-powered framework that combines supervised learning algorithms - such as Random Forest, XGBoost, and Neural Networks - with feature engineering and anomaly detection techniques to enhance fraud prediction accuracy. Experimental evaluations on benchmark datasets reveal a significant improvement in detection precision, achieving up to 95% accuracy while minimizing false positives. The framework offers scalability for government tax departments, regulatory agencies, and financial auditors, with future scope to integrate explainable AI (XAI) and real-time transaction monitoring for proactive risk mitigation. © 2025 IEEE.},
	author_keywords = {Anomaly Detection; Artificial Intelligence; Financial Risk Analysis; Income Tax Fraud Detection; Machine Learning; Supervised Learning Algorithms},
	keywords = {Crime; Economic analysis; Learning algorithms; Learning systems; Neural networks; Pattern recognition; Risk analysis; Supervised learning; Taxation; Anomaly detection; Financial integrity; Financial risk analysis; Fraud detection; Fraud detection system; Income tax; Income tax fraud detection; Machine-learning; Public trust; Supervised learning algorithm; Anomaly detection},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {979-833152253-7},
	language = {English},
	abbrev_source_title = {Int. Conf. Comput. Commun., COMPUTINGCON},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Wu1997291,
	author = {Wu, Rebecca C.},
	title = {Neural network models: Foundations and applications to an audit decision problem},
	year = {1997},
	journal = {Annals of Operations Research},
	volume = {75},
	pages = {291 - 301},
	doi = {10.1023/a:1018915714606},
	url = {https://www.scopus.com/pages/publications/0031329410?origin=resultslist},
	affiliations = {Department of Accounting, College of Management, National Taiwan University, Taipei, 106, Taiwan},
	abstract = {We investigate the possibility of applying artificial intelligence to solve an audit decision problem faced by the public sector (namely, the tax auditor of the Internal Revenue Services) when targeting firms for further investigation. We propose that the neural network will overcome problems faced by a direct knowledge acquisition method in building an expert system to preserve the expertise of senior auditors of the IRS in Taiwan. An explanation of the neural network theory is provided with regard to multi- and single-layered neural networks. Statistics reveal that the neural network performs favorably, and that three-layer networks perform better than two-layer neural networks. The results strongly suggest that neural networks can be used to identify firms requiring further auditing investigation, and also suggest future implications for intelligent auditing machines.},
	correspondence_address = {R.C. Wu; Department of Accounting, College of Management, National Taiwan University, Taipei, 106, Taiwan; email: rwu@haydn.ntu.edu.tw},
	publisher = {Kluwer Academic Publishers},
	issn = {02545330},
	language = {English},
	abbrev_source_title = {Ann. Oper. Res.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 9}
}

