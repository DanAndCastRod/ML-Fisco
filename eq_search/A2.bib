}

@ARTICLE{Nieuwenhuizen2025,
	author = {Nieuwenhuizen, E.N. and Trehan, V. and Porumbescu, G.},
	title = {Does Institutional Transparency Affect Citizen Trust in Predictive Policing? Evidence From a Survey-Experiment in The Netherlands},
