@ARTICLE{Kazun2024100,
	author = {Kazun, Anton P.},
	title = {CAN ARTIFICIAL INTELLIGENCE PREDICT JUDICIAL DECISIONS? A SYSTEMATIC REVIEW OF INTERNATIONAL RESEARCH; [МОЖЕТ ЛИ ИСКУССТВЕННЫЙ ИНТЕЛЛЕКТ ПРОГНОЗИРОВАТЬ РЕШЕНИЯ СУДА? СИСТЕМАТИЧЕСКИЙ ОБЗОР МЕЖДУНАРОДНЫХ ИССЛЕДОВАНИЙ]},
