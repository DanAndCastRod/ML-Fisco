	keywords = {Crime; Decision making; Ethical aspects; Information systems; International law; Social aspects; Algorithmic impact assessment; Algorithmics; Data driven; Ethical principles; Human rights; Impact assessments; Palantir; Predictive policing; Predpol; Trustworthy AI; Artificial intelligence},
