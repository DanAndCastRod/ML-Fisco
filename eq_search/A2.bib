@BOOK{Zalnieriute202597,
	author = {Zalnieriute, Monika},
	title = {From Procedural Fetishism to Substantive Due Process in AI Governance and Digital Constitutionalism},
	year = {2025},
	journal = {Artificial Intelligence and the Rule of Law: The Age of Legal Tech and Digital Governance in a Fractured Digital World},
	pages = {97 - 129},
	doi = {10.1007/978-3-031-97389-5_5},
	url = {https://www.scopus.com/pages/publications/105025634531?origin=resultslist},
	affiliations = {Faculty of Law, Vilnius University, Vilnius, Lithuania; Lithuanian Centre for Social Sciences, Vilnius, Lithuania},
	abstract = {As both states and private actors increasingly defer to artificial intelligence (AI) tools, the concept of due process is gaining new significant in the automated state. In this chapter, I argue that while due process and procedural safeguards are useful in managing abuse of power, nonetheless, due process is not a panacea that can alone temper power in the age of AI. I suggest that even if states and companies follow due process safeguards, such safeguards alone are not sufficient to address the power imbalance between individuals and citizens on the one hand, and the state and companies on the other. In fact, an obsession with due process in digital constitutionalist discourse is part of procedural fetishism—an overemphasis on the ability of procedural safeguards to limit state and corporate power. Procedural fetishism distracts the public from substantive questions as to the appropriateness and concentration of state and corporate power, and redirects them to the micro-issues, such as checklists and audits. I argue that an overemphasis on due process reinforces procedural fetishism and distracts from the significant dangers that AI tools, digital technologies, and tech companies pose to constitutional values, fundamental rights, and the rule of law, as well as our environment and social equality. To counter procedural fetishism, digital constitutionalism must revive the substantive conceptions of due process, which focus on limits of—and not just procedures for—power in the digital age. © 2025 The Editor(s) (if applicable) and The Author(s), under exclusive license to Springer Nature Switzerland AG.},
	author_keywords = {Artificial intelligence; Automation; Digital constitutionalism; Due process; Procedural fetishism; Technology},
	keywords = {Artificial intelligence tools; Corporate power; Digital constitutionalism; Digital technologies; Due process; Limit state; Power; Power imbalance; Procedural fetishism; Technology; Artificial intelligence; Automation},
	correspondence_address = {M. Zalnieriute; Faculty of Law, Vilnius University, Vilnius, Lithuania; email: monika.zalnieriute@tf.vu.lt},
	publisher = {Springer Science+Business Media},
