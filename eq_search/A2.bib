	url = {https://www.scopus.com/pages/publications/85206932841?origin=resultslist},
	affiliations = {UCLouvain, Belgium; UWA Law School, Australia},
	abstract = {In an era of global sanitary, economic and ecological crisis, beliefs in the predictive power of artificial intelligence (AI) progressively penetrate the legal and political spheres, in search of new ways to anticipate and govern the future. In this context, it is critical to understand the idiosyncratic nature of the interplay between governance and algorithmic logics of prediction. This contribution discusses how the association between governance and AI makes the future knowable in the present and shapes a programmatic way of formalising, justifying and deploying action in the here and now. We focus on three principles of institutional mobilisation in the face of uncertainty and indeterminacy: precaution, pre-emption and preparedness, each of which is affected by the use of AI relying on so-called 'real-time predictions'. Drawing from risk theory and Science and Technology Studies, we argue that the current convergence between AI and governance is shaping a new sociotechnical imaginary, promoting a distinctive conception of life and of the future in the age of the Anthropocene.  Copyright © The Author(s), 2022. Published by Cambridge University Press.},
	author_keywords = {AI and law; artificial intelligence; governance; predictive analytics; STS; uncertainty},
