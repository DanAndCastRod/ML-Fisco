@ARTICLE{Paché2025,
	author = {Paché, Gilles},
	title = {The Palletized Citizen: Surveillance, Mobility, and Algorithmic Urbanism},
	year = {2025},
	journal = {International Journal of E-Planning Research},
	volume = {14},
	number = {1},
	pages = {},
	doi = {10.4018/IJEPR.389050},
	url = {https://www.scopus.com/pages/publications/105017648796?origin=resultslist},
	affiliations = {Aix-Marseille University, France},
	abstract = {Urban environments are increasingly governed by digital infrastructures that mirror the vision of supply chain management. With the deployment of digital twins and real-time surveillance systems, cities are becoming spaces where citizens are monitored, sorted, and routed with the same efficiency-driven principles applied to goods in logistical networks. The emergence of what may be called the palletized citizen reflects this shift: individuals are treated as standardized, trackable units, whose trajectories through urban space are shaped by algorithms prioritizing flow optimization over human agency. While proponents emphasize gains in safety and efficiency, these technologies introduce profound ethical dilemmas. The integration of facial recognition and predictive behavior modeling points to a broader global trend that risks normalizing hyper-surveillance. This paper critically examines how the digital management of urban life increasingly aligns with logistical rationality, raising urgent questions about autonomy, privacy, and the future of public spaces. © 2025 IGI Global. All rights reserved.},
	author_keywords = {Algorithms; Data Privacy; Digital Twins; Facial Recognition; Palletized Citizen; Privacy; Security; Surveillance},
	keywords = {algorithm; autonomy; public space; supply chain management; urbanization},
	correspondence_address = {G. Paché; Aix-Marseille University, France; email: gilles.pache@univ-amu.fr},
	publisher = {IGI Global},
	issn = {21609918},
	language = {English},
	abbrev_source_title = {Intl. J. E Plan.  Res.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
}

