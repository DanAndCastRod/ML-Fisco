	source = {Scopus},
	note = {Cited by: 6; Conference name: 2022 ACM Symposium on Computer Science and Law, CSLAW 2022; Conference sponsors: ACM Professional; Conference code: 183985; Conference date: 1 November 2022 through 2 November 2022}
