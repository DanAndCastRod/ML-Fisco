@BOOK{Heupel2017297,
	author = {Heupel, Monika and Zürn, Michael},
	title = {The rise of human rights protection in international organizations-results and theoretical implications},
	year = {2017},
	journal = {Protecting the Individual from International Authority: Human Rights in International Organizations},
	pages = {297 - 331},
	doi = {10.1017/9781316756843.016},
	url = {https://www.scopus.com/pages/publications/85041002165?origin=resultslist},
	affiliations = {University of Bamberg, Germany; European University Institute, Italy; Free University of Berlin, Germany; WZB Berlin Social Science Center, Germany},
	abstract = {International organizations (IOs) were traditionally not deemed to be actors capable of violating international law, generally, or human rights law, specifically. They were either considered too weak to actually do wrong, or, if something did go wrong, it was assumed that it was the member states’ fault. With IOs having become sites of authority and actors in their own right, this view is now on the decline. While there is no consensus yet on what legal rules are binding on IOs, there is an emerging understanding among scholars in International Law (IL) that IOs can be responsible for wrongful acts and should be held accountable. This understanding has also taken hold beyond academia, as evidenced by the International Law Association’s (ILA) Final Report on the Accountability of International Organizations (ILA 2004) and the International Law Commission’s (ILC) Draft Articles on the Responsibility of International Organizations (ILC 2011). While some scholars have stressed the need for IOs to establish provisions for the protection of human rights, there has been less effort to show that they do indeed do so (but see Verdirame 2011) and effectively none to explain why they increasingly acknowledge this need - or why some do better than others. The objective of this book has been to answer precisely these open questions. We set out to show that IOs establish provisions for the protection of human rights. We also present a general mechanism, together with related pathways, that sheds light on why IOs accept their responsibility for the protection of human rights. This conclusion summarizes the results and discusses the theoretical implications of our findings. We show in the first section that all the IOs in our sample have introduced provisions for the protection of human rights in the policies selected for analysis (Section 1.1). Subsequently, we provide support for the authority-legitimation mechanism (ALM), which posits that authoritative IOs introduce human rights protection provisions to legitimate themselves. We also specify the four pathways (legislative, judicial, like-minded and anticipatory institution-building) that clarify how the ALM unfolds in practice, and name the trigger and success conditions of each pathway (Section 1.2). © Cambridge University Press 2017.},
	publisher = {Cambridge University Press},
	isbn = {978-131675684-3; 978-110717082-7},
	language = {English},
	abbrev_source_title = {Protecting the Individual from International Auth.: Hum. Rights in International Organizations},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 23}
}

