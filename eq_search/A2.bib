}

@ARTICLE{Infantino2024187,
	author = {Infantino, Marta and Bussani, Mauro},
	title = {Rule by Metrics Performance, Quantification, and the Law},
	year = {2024},
	journal = {European Journal of Comparative Law and Governance},
	volume = {11},
