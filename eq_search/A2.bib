@ARTICLE{Romero2024168,
	author = {Romero, Lorayne Finol and Villarroel, Ivette Esis},
	title = {Transparency of artificial intelligence in public administration: a review of international standards; [Transparência da inteligência artificial na administração pública: uma revisão dos estândares internacionais]; [Transparencia de la inteligencia artificial en la administración pública: una revisión de estándares internacionales]},
	year = {2024},
