@ARTICLE{Birahim2025,
	author = {Birahim, Shaikh Afnan},
	title = {Contesting the algorithm: advancing a right to challenge AI decisions under the GDPR for algorithmic fairness},
	year = {2025},
	journal = {Transforming Government: People, Process and Policy},
	pages = {},
	doi = {10.1108/TG-05-2025-0148},
	url = {https://www.scopus.com/pages/publications/105017728801?origin=resultslist},
	affiliations = {School of Computing Science, University of Glasgow, Glasgow, United Kingdom},
	abstract = {Purpose – This study aims to challenge the adequacy of Article 22 of the General Data Protection Regulation (GDPR) in safeguarding individuals against harmful automated decisions. It argues that explainability alone is insufficient for algorithmic accountability and proposes a legally enforceable right to contest such decisions. Through comparative legal analysis, it reveals the shortcomings of current GDPR protections and advocates for an amended framework that empowers individuals with substantive rights and remedies. The goal is to enable individuals not only to understand but also to challenge, correct or overturn artificial intelligence (AI)-driven decisions that significantly affect their lives. Design/methodology/approach – This study adopts a qualitative comparative case study approach, analyzing enforcement and contestability in eight jurisdictions: four under the GDPR (The Netherlands, UK, France and Germany) and four outside it (California, New York City and Canada – public and private sectors). Data sources include legal texts, academic literature, court rulings and policy documents. A structured analytical matrix was applied to assess algorithm type, sector, availability of contestability mechanisms and enforcement effectiveness. This desk-based comparative legal analysis triangulates secondary sources to identify regulatory gaps and formulate reform proposals for strengthening contestability rights in AI governance. Findings – The analysis reveals that GDPR Article 22 is functionally weak due to vague language, broad exceptions and limited enforcement. In practice, individuals rarely access meaningful mechanisms to contest consequential AI-driven decisions. By contrast, non-GDPR jurisdictions such as California and Canada show more proactive governance through opt-out rights, bias audits and algorithmic impact assessments. This study finds that effective contestability requires not only individual rights but also institutional safeguards, including human-in-the-loop review, independent oversight and public accountability mechanisms. Transparency alone is insufficient – robust, enforceable procedural rights are essential to ensure fairness and protect affected individuals. Originality/value – This paper offers a novel ethical and legal case for rethinking algorithmic fairness beyond explainability, introducing a structured proposal to amend GDPR Article 22. It moves the discourse from transparency to contestability, grounded in comparative case analysis across EU and non-EU jurisdictions. The work bridges theoretical critique and practical reform, offering actionable policy recommendations, including an explicit right to contest, standards for human review and regulatory oversight models. It contributes original insights into how algorithmic harms can be addressed through due process-based contestation rights, reinforcing autonomy, fairness and justice in AI governance. © 2025 Emerald Publishing Limited},
	author_keywords = {AI accountability; AI governance; Algorithmic contestability; GDPR Article 22; Right to contest},
	publisher = {Emerald Publishing},
	issn = {17506166},
	language = {English},
	abbrev_source_title = {Trans. Gov. People Process Policy},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 1}
}

@BOOK{Suksi202365,
	author = {Suksi, Markku},
	title = {Formal, procedural, and material requirements of the rule of law in the context of automated decision-making},
	year = {2023},
	journal = {The Rule of Law and Automated Decision-Making: Exploring Fundamentals of Algorithmic Governance},
	pages = {65 - 95},
	doi = {10.1007/978-3-031-30142-1_4},
	url = {https://www.scopus.com/pages/publications/85194450573?origin=resultslist},
	affiliations = {Department of Law, Åbo Akademi University, Turku/Åbo, Finland},
	abstract = {The rule of law requirements concerning automated decision-making are approached from the viewpoint of formal, procedural, and material requirements. The chapter argues that in addition to a clear legal basis for automated decision-making, formal rule of law also contains the requirement that automated decision-making should be based on legal reasoning, that is, subsumption of legal facts under a norm. This impacts the choice of technology for the system of automated decision-making by expecting that only such techniques are used which can reproduce subsumption. This means that rule-based solutions are possible for automated decision-making, while machine-learning-based applications, which are based on statistical inferences leading to predictions, are normally not. Procedural rule of law requires that good government, such as the right of motivation, right of an individual to be heard, and transparency of decision-making should be guaranteed. Material rule of law requires that aspects of substantive law, such as different benefit levels and conditions for granting benefits, are properly considered when the algorithm and the source code are developed. These requirements are relevant for all situations where automated decision-making is used, exemplified in this context by practice from the Finnish supervisors of legality and the Constitutional Law Committee of the Finnish Parliament. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2023. All rights reserved.},
	author_keywords = {Automated decision-making; Legal reasoning; Machine learning; Rule-based systems; Subsumption},
	correspondence_address = {M. Suksi; Department of Law, Åbo Akademi University, Turku/Åbo, Finland; email: markku.suksi@abo.fi},
	publisher = {Springer International Publishing},
