	year = {2023},
	journal = {Sentencing and Artificial Intelligence},
	pages = {252 - 276},
	doi = {10.1093/oso/9780197539538.003.0013},
	url = {https://www.scopus.com/pages/publications/85152304414?origin=resultslist},
	affiliations = {University of Aarhus, Denmark},
	abstract = {Automated decision-making for sentencing is the use of a software algorithm to analyze a convicted offender’s case and deliver a sentence. This chapter reviews the moral arguments for and against employing automated decision-making for sentencing. Specifically, it argues that well-designed automated decision-making for sentencing will better approximate the just sentence than human sentencers. Moreover, it dismisses common concerns about transparency, privacy, and bias as unpersuasive or inapplicable. The chapter also notes that moral disagreement about theories of just sentencing are plausibly resolved by applying the principle of maximizing expected moral choice worthiness, and that automated decision-making is better suited to the resulting ensemble model. Finally, the chapter considers the challenge posed by penal populism. The dispiriting conclusion is that although it is in theory morally desirable to use automated decision-making for criminal sentencing, it may well be the case that we ought not to try. © Oxford University Press 2022. All rights reserved.},
	author_keywords = {Automated decision-making; Bias; Criminal justice ethics; Decision theory; Moral uncertainty; Penal populism; Privacy; Transparency},
