	abbrev_source_title = {J. Acc. Emerg. Econ.},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 4}
}

@BOOK{Talesh20251,
	author = {Talesh, Shauhin A.},
	title = {Insuring cyberinsecurity: Insurance companies as symbolic regulators},
