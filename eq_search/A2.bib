@BOOK{Aloisi20221,
	author = {Aloisi, Antonio and De Stefano, Valerio},
	title = {Your boss is an algorithm: Artificial intelligence, platform work and labour},
	year = {2022},
	journal = {Your Boss Is an Algorithm: Artificial Intelligence, Platform Work and Labour},
	pages = {1 - 190},
