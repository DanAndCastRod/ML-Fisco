@ARTICLE{Kinchin2024,
	author = {Kinchin, Niamh},
	title = {“Voiceless”: the procedural gap in algorithmic justice},
	year = {2024},
	journal = {International Journal of Law and Information Technology},
	volume = {32},
	number = {1},
	pages = {},
	doi = {10.1093/ijlit/eaae024},
	url = {https://www.scopus.com/pages/publications/85208741545?origin=resultslist},
	affiliations = {School of Law, Faculty of Business and Law, University of Wollongong, Northfields Avenue, Wollongong, NSW, Australia},
	abstract = {Conversations about algorithms and fairness can overlook the bifurcation of justice. Whilst distributive justice is integral to accountability for algorithmic bias and related harms, without procedural justice and ‘voice’, defined as consent, transparency, and a right to be heard, algorithmic decisions will fail to find legitimacy and acceptance. Fairness metrics respond better to distributive justice because algorithmic bias is primarily framed in such terms. The potential of AI Ethics Guidelines and formal regulation to address voice is compromised by ambiguous concepts of fairness, rigidity, and competing market demands. The scope of a right to a fair trial limits the potential of human rights impact assessments to address procedural rights. Jurisdictional issues of reviewability, interpretation, and applicability challenge judicial review. In examining the capacity of these accountability mechanisms to ensure ‘voice’, a ‘procedural gap’ emerges in algorithmic decision-making. © The Author(s) 2024. Published by Oxford University Press.},
	author_keywords = {AI ethics guidelines; algorithmic justice; consent; fairness metrics; human rights; judicial review; procedural justice; regulation; right to be heard; transparency},
	correspondence_address = {N. Kinchin; School of Law, Faculty of Business and Law, University of Wollongong, Wollongong, Northfields Avenue, Australia; email: nkinchin@uow.edu.au},
	publisher = {Oxford University Press},
	issn = {09670769},
	language = {English},
	abbrev_source_title = {Int. J. Law Inf. Technol.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 8; All Open Access; Hybrid Gold Open Access}
}

