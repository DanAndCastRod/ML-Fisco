	year = {2023},
	journal = {Politics of Citizenship and Migration},
	volume = {Part F1658},
	pages = {295 - 322},
	doi = {10.1007/978-3-031-16548-1_12},
	url = {https://www.scopus.com/pages/publications/85176557250?origin=resultslist},
	affiliations = {Rhodes University, Grahamstown, South Africa},
	abstract = {The right to education which includes primary education, is an internationally guaranteed right. The United Nations Convention on the Rights of the Child (UNCRC), African Charter on the Rights and Welfare of the Child (ACRWC) and the International Covenant on Economic, Social and Cultural Rights (ICESCR) establish a set of rights that are legally binding on governments that had ratified these conventions. Zimbabwe has acceded to these conventions and is thus expected to give effect to the advancement and implementation of the right to education. Furthermore, the 2013 Constitution crystallised children’s rights by aligning domestic laws with the international conventions. Despite this commitment, Zimbabwe’s encampment policy has inadvertently hindered access to education for unaccompanied refugee children. This policy restricts refugees and asylum seekers from residing in any other area of the country, save for the designated site. Tongogara Refugee Camp has been designated as the only place refugees can stay in. There is no differentiation regarding the various demographics of the refugees. Under the circumstances, with limited agency and extreme vulnerability due to the prevailing humanitarian conditions, unaccompanied refugee children are excluded. This also means they cannot develop, which perpetuates their vulnerability and continues the refugee cycle. Against this backdrop, the chapter considers how this policy presents an encumbrance on the right to education and subsequent child development. It argues that the policy undermines the right to education and tests the applicability of this policy within the confines of Zimbabwe’s domestic and international obligations towards the education of all children despite their origin. The chapter highlights critical policy implementation instruments, such as integration, that can be used to inclusively realise the right to education in Zimbabwe. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2023.},
