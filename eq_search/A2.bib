@ARTICLE{Hansen2021109,
	author = {Hansen, Hans Krause and Weiskopf, Richard},
	title = {From Universalizing Transparency to the Interplay of Transparency Matrices: Critical insights from the emerging social credit system in China},
	year = {2021},
