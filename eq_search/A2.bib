@ARTICLE{Price2021775,
	author = {Price, W. Nicholson and Rai, Arti K.},
	title = {Clearing opacity through machine learning},
	year = {2021},
	journal = {Iowa Law Review},
	volume = {106},
	number = {2},
	pages = {775 - 812},
	url = {https://www.scopus.com/pages/publications/85104631626?origin=resultslist},
	affiliations = {University of Michigan Law School, The Center for Advanced Studies of Biomedical Innovation Law, United States; University of Copenhagen, Faculty of Law, Denmark; Center for Innovation Policy at Duke Law School, Core Faculty, The Duke-Margolis Center for Health Policy, United States},
	abstract = {Artificial intelligence and machine learning represent powerful tools in many fields, ranging from criminal justice to human biology to climate change. Part of the power of these tools arises from their ability to make predictions and glean useful information about complex real-world systems without the need to understand the workings of those systems. But these machine-learning tools are often as opaque as the underlying systems, whether because they are complex, nonintuitive, deliberately kept secret, or a synergistic combination of those three factors. A burgeoning literature addresses challenges arising from the opacity of machine-learning systems. This literature has largely focused on the benefits and difficulties of providing information to lay individuals, such as citizens impacted by algorithm-driven government decisions. In this Essay, we explore the potential of machine learning to clear opacity - that is, to help drive scientific understanding of the frequently complex and nonintuitive real-world systems that machine-learning algorithms examine. Using examples drawn from cutting-edge scientific research, we argue machine-learning algorithms can advance fundamental scientific knowledge and that deliberate secrecy around machine-learning tools restricts that learning enterprise. © 2021 University of Iowa. All rights reserved.},
	publisher = {University of Iowa},
	issn = {00210552},
	language = {English},
	abbrev_source_title = {Iowa Law Rev.},
	type = {Review},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 23}
}

@ARTICLE{Gluck20151789,
	author = {Gluck, Abbe R. and O’Connell, Anne Joseph and Po, Rosa},
	title = {Unorthodox lawmaking, unorthodox rulemaking},
	year = {2015},
	journal = {Columbia Law Review},
	volume = {115},
	number = {7},
	pages = {1789 - 1866},
	url = {https://www.scopus.com/pages/publications/84949189130?origin=resultslist},
	affiliations = {Solomon Center for Health Law and Policy, Yale Law School, United States; Berkeley Law School (Boalt Hall), United States; Yale Law School, United States},
	abstract = {The Schoolhouse Rock! cartoon version of the conventional legislative process is dead, if it was ever an accurate description in the first place. Major policy today is often the product of “unorthodox lawmaking” and “unorthodox rulemaking”—deviations from traditional process marked by frequent use of omnibus bills and multiple agency implementation; emergency statutes and regulations issued without prior comment; outsourcing to lawmaking commissions and unconventional delegates; process shortcuts outside of emergencies; presidential policymaking; and outside drafters, some nonpartisan and others hyperpartisan. These unorthodoxies are everywhere, and they have shifted the balance in the elected branches and beyond, often centralizing power in actors—like party leadership and the White House—not traditionally part of the core lawmaking and rulemaking processes. These unorthodoxies are the new textbook process. The theories and doctrines of legislation and administrative law, however, have paid little attention to these evolutions. The limited commentary that does exist tends to lump all unorthodox policymaking together or to preserve an artificial divide between their legislative and administrative manifestations. But omnibus policymaking is different from emergency policymaking—not only in process and product, but in the challenges that each poses for courts. And both forms of policymaking are different from presidential policymaking, and so on. Unorthodoxies in one branch are also closely linked to unorthodoxies in the other. © 2015, Columbia Law Review Association. All Rights Reserved.},
	publisher = {Columbia Law Review Association},
	issn = {00101958},
	language = {English},
	abbrev_source_title = {Columbia Law Rev.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 78}
}

