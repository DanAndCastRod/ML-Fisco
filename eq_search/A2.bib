	pages = {94 - 108},
	doi = {10.4337/9781803922171.00014},
	url = {https://www.scopus.com/pages/publications/85207576140?origin=resultslist},
	affiliations = {Faculty of Law, University of Cambridge, United Kingdom; Department of Computer Science and Technology (Computer Laboratory), University of Cambridge, United Kingdom},
	abstract = {Accountability is often seen as important for understanding AI technologies and protecting people and societies from harm. Yet ‘algorithmic accountability’ is contested, with different meanings, understandings, and approaches that have changed over time. To bring some clarity to these discussions, we draw out broad trends in algorithmic accountability research over the last decade. We frame these developments in terms of two key distinctions: first, between a first and second wave of research; second, between different understandings of accountability. In doing so, we highlight the fundamentally contextual nature of accountability – both in terms of the need to capture the broader context of AI systems, and the need to have contextually appropriate information about AI technologies. Building on this, we argue for contextual algorithmic accountability mechanisms for affected people and communities to contest and resist the AI-enabled forms of power, production, discipline, and control they face. © Editors and Contributors Severally 2024.},
	author_keywords = {Algorithmic accountability; Algorithmic supply chains; Automated decision-making; Contextual accountability; Explainable AI; Participatory AI},
