@ARTICLE{Gikay2025552,
	author = {Gikay, Asress Adimi},
	title = {Trade secrecy in automated decisions: against the myth of irreconcilability and the imposition of patents},
	year = {2025},
	journal = {Journal of Intellectual Property Law and Practice},
	volume = {20},
	number = {8},
	pages = {552 - 561},
	doi = {10.1093/jiplp/jpaf038},
