@ARTICLE{Gu2025,
	author = {Gu, Yanfeng and Zheng, Bingdao and Li, Ziying and Li, Yaning},
	title = {The Institutional Mediation of Algorithmic Power: China’s Social Credit System in Comparative Perspective},
	year = {2025},
