	affiliations = {Al-Ahliyya Amman University, Faculty of Law, Public Law Department, Jordan; Abu Dhabi University, Faculty of Law, Civil Law, United Arab Emirates; University of Jordan, Faculty of Law, Public Law Department, Jordan; Applied Science Private University, Faculty of Law, Public Law Department, Jordan; Jordanian Institute for Public Administration, Jordan; Al-Ahliyya Amman University, Faculty of Law, Private Law Department, Jordan},
