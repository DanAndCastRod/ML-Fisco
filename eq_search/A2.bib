@ARTICLE{Waldman20242021,
	author = {Waldman, Ari Ezra},
	title = {Opening the Gender Box: Legibility Dilemmas and Gender Data Collection on U.S. State Government Forms},
	year = {2024},
	journal = {Law and Social Inquiry},
	volume = {49},
	number = {4},
	pages = {2021 - 2051},
