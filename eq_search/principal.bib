@ARTICLE{Nefla2025,
	author = {Nefla, Dhouha and Jellouli, Sana},
	title = {Emerging technologies in finance: challenges for a sustainable finance},
	year = {2025},
	journal = {Cogent Business and Management},
	volume = {12},
