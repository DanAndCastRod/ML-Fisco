@ARTICLE{Levy2026,
	author = {Levy, Haim V.},
	title = {Personalized law and personalized medicine: a critical study of normative divergence in the age of AI governance},
	year = {2026},
	journal = {Law, Ethics and Technology},
	volume = {3},
